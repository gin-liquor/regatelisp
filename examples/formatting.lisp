; 基数整数リテラルと剰余演算
0b1111_0000
0xDEAD_BEEF
(% 10 3)
(% -10 3)

; 文字列リテラルとエスケープ
"hello"
"line1\nline2"

; print: 基本、基数、幅・配置・埋め文字・符号
(print "hello\n")
(print "x={} y={}\n" 10 20)
(print "{1} {0}\n" 10 20)
(print "dec={} hex={:#04x} bin={:#010b}\n" 255 255 255)
(print "|{:<8}|{:>8}|{:^8}|\n" 123 123 123)
(print "|{:*>8}|\n" 123)
(print "{:+} {:+}\n" 10 -10)
